# Copy to .env.local and fill in. NEVER commit real secrets.
# Only NEXT_PUBLIC_* vars are exposed to the browser — keep everything else server-only.

# Canonical site URL (used for metadata, canonical, sitemap, OG).
# Vercel sets this per environment; locally it falls back to https://visintia.com
NEXT_PUBLIC_SITE_URL=https://visintia.com

# --- Contact form email (server-only, do NOT prefix with NEXT_PUBLIC_) ---
# Without RESEND_API_KEY the form still works and logs leads to the server.
# Set it (https://resend.com → API Keys) to deliver leads by email.
# RESEND_API_KEY=re_xxxxxxxx
# Where leads are delivered:
# CONTACT_TO_EMAIL=info@visintia.com
# Sender. For testing use "onboarding@resend.dev"; in production verify the
# visintia.com domain in Resend and use e.g. "Visintia <no-reply@visintia.com>".
# CONTACT_FROM_EMAIL=Visintia <no-reply@visintia.com>

# --- Future: auth / client area (when the (app) route group is added) ---
# AUTH_SECRET=
# DATABASE_URL=
